---
import '../styles/global.css';
import { SITE, NAV } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  canonical,
  noindex = false,
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE.title}` : SITE.title;
const canonicalUrl = canonical ? new URL(canonical, Astro.site) : Astro.url;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonicalUrl} />
    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />
    <!-- Favicon (CSS-only, no image) -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%23070a12'/><rect x='20' y='20' width='60' height='60' rx='10' fill='none' stroke='%2352d4ff' stroke-width='8' transform='rotate(45 50 50)'/></svg>" />
  </head>
  <body>
    <header class="topbar">
      <div class="topbar-inner">
        <a class="brand" href="/">
          <span class="mark" aria-hidden="true"></span>
          <span class="brand-text">
            <strong>{SITE.gameName} Helper</strong>
            <span>{SITE.platform} • Unofficial</span>
          </span>
        </a>
        <nav class="nav" aria-label="Primary navigation">
          {NAV.map(item => (
            <a
              href={item.url}
              class={Astro.url.pathname === item.url ? 'active' : ''}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="shell">
      <slot />
    </main>

    <footer class="shell" style="padding-top: 0; padding-bottom: 32px;">
      <p class="footer-note">
        <strong>{SITE.title}</strong> is an unofficial player helper, not affiliated with Roblox or {SITE.creator}.<br />
        All game facts come from publicly available Roblox API data · Last checked {SITE.metricsDate}
      </p>
    </footer>
  </body>
</html>
